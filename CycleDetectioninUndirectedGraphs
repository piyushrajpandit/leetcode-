string cycleDetection(vector<vector<int>> &edges, int n, int m) {

    unordered_map<int, list<int>> adj;

    for (int i = 0; i < m; i++) {
        int u = edges[i][0];
        int v = edges[i][1];

        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    unordered_map<int, bool> visited;

    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            if (isCyclicBFS(i, visited, adj)) {
                return "YES";
            }
        }
    }

    return "NO";
}
